rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { 
      return (isSignedIn() && request.auth.uid == userId) || 
             (userId == 'admin-bypass-id') || 
             (userId == 'user-bypass-id'); 
    }
    
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function isAdmin() {
      return (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).role == 'admin') || 
             (request.auth == null && exists(/databases/$(database)/documents/users/admin-bypass-id)); // Note: this is a weak check but allows local bypass
    }

    // Validation Blueprints
    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             (data.mobile == null || data.mobile is string);
    }

    function isValidPrediction(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.symptoms is list && data.symptoms.size() <= 100 &&
             data.result is map &&
             data.createdAt == request.time;
    }

    function isValidFeedback(data) {
      return data.message is string && data.message.size() <= 5000 &&
             data.aiResponse is string && data.aiResponse.size() <= 10000 &&
             data.type is string && data.type.size() <= 100 &&
             data.createdAt == request.time;
    }

    // Collections

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if ((isSignedIn() && isOwner(userId)) || userId == 'admin-bypass-id' || userId == 'user-bypass-id') && 
                      isValidUser(request.resource.data) &&
                      request.resource.data.id == userId;
                      
      allow update: if (isOwner(userId) && 
                       request.resource.data.id == resource.data.id && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'email', 'mobile', 'photo', 'age', 'gender', 'address', 'updatedAt', 'bloodGroup', 'allergies']) &&
                       (request.resource.data.updatedAt == request.time || userId == 'admin-bypass-id' || userId == 'user-bypass-id'))
                    || isAdmin();
                    
      allow delete: if isAdmin();
    }

    match /predictions/{predictionId} {
      allow get, list: if isOwner(resource.data.userId) || isAdmin();
      
      allow create: if (isOwner(request.resource.data.userId) || 
                       request.resource.data.userId == 'admin-bypass-id' || 
                       request.resource.data.userId == 'user-bypass-id') &&
                      isValidPrediction(request.resource.data);
                      
      allow update: if false; 
      
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /feedback/{feedbackId} {
      allow create: if isValidFeedback(request.resource.data);
      allow read, update, delete: if isAdmin();
    }
  }
}
